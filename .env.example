# SynergyAI 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改配置

# ====================
# 应用配置
# ====================
PYTHONUNBUFFERED=1
LOG_LEVEL=INFO

# ====================
# API 服务配置
# ====================
API_HOST=0.0.0.0
API_PORT=8000

# ====================
# OpenAI API 配置
# ====================
# 如果使用 OpenAI API，请设置以下环境变量
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# 如果使用其他兼容 OpenAI 的 API（如 Azure OpenAI），请修改 BASE_URL
# OPENAI_BASE_URL=https://your-azure-openai-endpoint/openai/deployments/your-deployment

# ====================
# 数据库配置
# ====================
# 默认使用 SQLite，数据库文件位于 data/synergyai.db
# 如需使用 PostgreSQL，请取消注释并配置以下变量：
# DATABASE_URL=postgresql://user:password@localhost:5432/synergyai

# ====================
# 安全配置
# ====================
# 生产环境建议设置强密钥
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32

# CORS 配置（允许的前端域名）
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# ====================
# 性能配置
# ====================
# WebSocket 连接超时（秒）
WEBSOCKET_TIMEOUT=600

# 最大任务并发数
MAX_CONCURRENT_TASKS=5
